APP_NAME=dify-fastapi
APP_VERSION=1.0.0
LOG_LEVEL=INFO

OPENAI_API_KEY=replace-with-your-api-key
OPENAI_BASE_URL=http://198.18.0.1:1234/v1
OPENAI_MODEL=qwen/qwen3.5-9b
DIFY_API_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_TARGET_SCORE_OUTLINE=85
DIFY_TARGET_SCORE_DRAFT=90

OPENAI_CONNECT_TIMEOUT_SECONDS=5
OPENAI_READ_TIMEOUT_SECONDS=60
OPENAI_WRITE_TIMEOUT_SECONDS=10
DIFY_CONNECT_TIMEOUT_SECONDS=5
DIFY_READ_TIMEOUT_SECONDS=180
DIFY_WRITE_TIMEOUT_SECONDS=10
HEALTH_DEEP_TIMEOUT_SECONDS=5

CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CHAT_DATABASE_PATH=data/chat.sqlite3
CHAT_ASSETS_DIR=data/chat-assets
CHAT_UPLOADS_DIR=data/chat-uploads
CHAT_MAX_IMAGES_PER_MESSAGE=4
CHAT_MAX_IMAGE_BYTES=5000000
CHAT_UPLOAD_TTL_SECONDS=3600
